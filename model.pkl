   "source": [
    "df = pd.read_csv(\"D:/Kalika per.projects/cs-training.csv\")\n",
    "\n",
    "# remove unwanted column\n",
    "if \"Unnamed: 0\" in df.columns:\n",
    "    df.drop(\"Unnamed: 0\", axis=1, inplace=True)\n",
    "\n",
    "df.fillna(df.median(), inplace=True)"
   ]
  },
